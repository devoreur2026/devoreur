# Copy this file to `.env` and fill in your Supabase project values.
# `.env` is gitignored — never commit real values. On Render, set these as
# environment variables in the dashboard instead of using a file.
#
# Both are safe to expose to the browser (the anon key is a *publishable* key);
# they're kept in env vars per project convention, and the server serves them to
# the client via /api/config.

# Your project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=

# Your project's publishable / anon key (Project Settings -> API)
SUPABASE_ANON_KEY=
