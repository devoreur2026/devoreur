# Copy this file to `.env` and fill in your Supabase project values.
# `.env` is gitignored — never commit real values. On Render, set these as
# environment variables in the dashboard instead of using a file.
#
# Both are safe to expose to the browser (the anon key is a *publishable* key);
# they're kept in env vars per project convention, and the server serves them to
# the client via /api/config.

# Your project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=

# Your project's publishable / anon key (Project Settings -> API)
SUPABASE_ANON_KEY=

# SECRET — server only, never exposed to the browser. Enables durable Supabase
# persistence of the money ledger (run db/schema.sql first). Without it the
# economy runs in-memory only (fine for local dev / ledger-mode testing).
# Project Settings -> API -> service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# ── Phase 2: real-money payments via Unipesa (server-only; never exposed) ──
# Payments stay OFF unless PAYMENTS_ENABLED=1 AND all four credentials are set.
# Run db/payments.sql in Supabase first (records persist via the service role
# key above). When off, the deposit/withdraw UI is hidden and endpoints reject.
PAYMENTS_ENABLED=0
UNIPESA_API_BASE=
UNIPESA_PUBLIC_ID=
UNIPESA_MERCHANT_ID=
UNIPESA_SECRET_KEY=
# Public https base used to build the gateway callback URL, e.g.
# https://devoreur.com  (if unset, it's derived from the request host).
PUBLIC_URL=
# Optional integer-CDF overrides (defaults 1000 / 5000 / 200000):
# DEPOSIT_MIN=
# WITHDRAW_MIN=
# WITHDRAW_DAILY_CAP=
