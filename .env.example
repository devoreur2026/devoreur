# Copy this file to `.env` and fill in your Supabase project values.
# `.env` is gitignored — never commit real values. On Render, set these as
# environment variables in the dashboard instead of using a file.
#
# Uses the NEW Supabase API keys (Project Settings -> API keys). The legacy
# anon/service_role keys are deprecated — migrate off them and disable them.

# Your project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=

# Browser-safe PUBLISHABLE key (sb_publishable_...). Replaces the legacy anon
# key; the server serves it to the client via /api/config.
SUPABASE_PUBLISHABLE_KEY=

# SECRET server key (sb_secret_...) — server only, NEVER exposed to the browser.
# Replaces the legacy service_role key. Enables durable Supabase persistence of
# the ledger + payments (run db/schema.sql and db/payments.sql first). Without
# it the economy runs in-memory only (fine for local dev / ledger-mode testing).
SUPABASE_SECRET_KEY=

# ── Phase 2: real-money payments via Unipesa (server-only; never exposed) ──
# Payments stay OFF unless PAYMENTS_ENABLED=1 AND all four credentials are set.
# Run db/payments.sql in Supabase first (records persist via SUPABASE_SECRET_KEY
# above). When off, the deposit/withdraw UI is hidden and endpoints reject.
PAYMENTS_ENABLED=0
UNIPESA_API_BASE=
UNIPESA_PUBLIC_ID=
UNIPESA_MERCHANT_ID=
UNIPESA_SECRET_KEY=
# Public https base used to build the gateway callback URL, e.g.
# https://devoreur.com  (if unset, it's derived from the request host).
PUBLIC_URL=
# Optional integer-CDF overrides (defaults 1000 / 5000 / 200000):
# DEPOSIT_MIN=
# WITHDRAW_MIN=
# WITHDRAW_DAILY_CAP=
